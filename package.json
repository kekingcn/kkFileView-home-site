{
  "name": "website",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=26.1.0"
  },
  "scripts": {
    "generate": "node scripts/generate-site.cjs",
    "prestart": "npm run generate",
    "start": "vite --host 0.0.0.0 --port 8082 --strictPort",
    "predev": "npm run generate",
    "dev": "vite --host 0.0.0.0 --port 8082 --strictPort",
    "prebuild": "npm run generate",
    "build": "vite build",
    "postbuild": "node scripts/copy-static.cjs",
    "preview": "vite preview --host 0.0.0.0 --port 8082 --strictPort",
    "lint": "eslint src utils site_config scripts --ext .js,.jsx,.cjs,.mjs",
    "lint:fix": "eslint src utils site_config scripts --ext .js,.jsx,.cjs,.mjs --fix"
  },
  "dependencies": {
    "classnames": "^2.2.6",
    "js-cookie": "^2.2.1",
    "prop-types": "^15.8.1",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-scroll": "^1.8.1",
    "whatwg-fetch": "^2.0.4"
  },
  "devDependencies": {
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/eslint-parser": "^7.28.6",
    "@vitejs/plugin-react": "^6.0.1",
    "ejs": "^3.1.10",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-github-preamble": "^1.0.0",
    "sass": "^1.99.0",
    "vite": "^8.0.12"
  }
}
